#!/bin/bash
# Float laptop input devices when Planck keyboard is connected

# Check if an external keyboard is connected
if ! xinput list | grep -qE "Drop Planck|foostan Corne"; then
    echo "No external keyboard connected, doing nothing"
    exit 0
fi

echo "External keyboard detected, floating laptop inputs..."

# Devices to float (keeping touchpad active intentionally)
devices=(
    "AT Translated Set 2 keyboard"
    "TPPS/2 Elan TrackPoint"
    "ThinkPad Extra Buttons"
)

for device in "${devices[@]}"; do
    id=$(xinput list | grep "$device" | grep -oP 'id=\K\d+')
    if [ -n "$id" ]; then
        xinput float "$id"
        echo "Floated: $device (id=$id)"
    else
        echo "Not found: $device"
    fi
done

echo "Done"
